{
  "name": "gestao-biblioteca",
  "version": "1.0.0",
  "description": "API REST para gerenciamento de biblioteca pessoal",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "mocha test/**/*.test.js --exit --timeout 10000",
    "test:report": "mocha test/**/*.test.js --exit --timeout 10000 --reporter mochawesome --reporter-options reportDir=mochawesome-report,reportFilename=relatorio,overwrite=true",
    "perf:smoke": "k6 run performance/load-tests/smoke-test.js",
    "perf:load": "k6 run performance/load-tests/load-test.js",
    "perf:stress": "k6 run performance/load-tests/stress-test.js",
    "perf:soak": "k6 run performance/load-tests/soak-test.js"
  },
  "keywords": [
    "library",
    "api",
    "rest",
    "express",
    "jwt"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mochawesome": "^7.1.4",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "chai": "^4.3.10",
    "mocha": "^10.2.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  }
}
